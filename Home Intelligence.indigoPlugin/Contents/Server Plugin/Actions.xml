<?xml version="1.0"?>
<Actions>
    <!-- IWS HTTP endpoint for external feedback channels (future iMessage
         plugin, webhooks, etc). Hidden from the Indigo UI. Requests are
         verified against an internal HMAC-SHA256 signature. The inbox
         poller bypasses this and calls _dispatch_feedback directly,
         so this route is currently unused in-tree.
         URL: POST /message/com.simons-plugins.home-intelligence/feedback -->
    <Action id="feedback" uiPath="hidden">
        <Name>Feedback Webhook</Name>
        <CallbackMethod>handle_feedback</CallbackMethod>
    </Action>

    <!-- Health check endpoint. Unauthenticated; returns plugin name. -->
    <Action id="status" uiPath="hidden">
        <Name>Plugin Status (HTTP)</Name>
        <CallbackMethod>handle_status</CallbackMethod>
    </Action>

    <!-- Programmatic trigger for a digest run. Same flow as the
         "Run Digest Now" menu item but callable from:
           - An Indigo Action Group step ("Execute Plugin Action")
           - A Python script: plugin.executeAction("runDigest")
           - IWS HTTP:  POST /message/com.simons-plugins.home-intelligence/runDigest
         uiPath="hidden" keeps it out of the user-facing action menus;
         digests are an internal/automated concern, not a per-device
         action users should be adding ad-hoc. -->
    <Action id="runDigest" uiPath="hidden">
        <Name>Run Digest</Name>
        <CallbackMethod>handle_run_digest</CallbackMethod>
    </Action>
</Actions>
